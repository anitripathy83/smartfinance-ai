<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_financial_report_form" model="ir.ui.view">
    <field name="name">smartfinance.report.form</field>
    <field name="model">smartfinance.report</field>
    <field name="arch" type="xml">
      <form string="Financial Report" create="false">
        <sheet>
          <h1><field name="name" readonly="1"/></h1>
          <p>Generated on: <field name="date_generated" readonly="1"/></p>

          <group string="💰 Cash Flow Summary (Last 30 Days)">
            <group>
              <field name="total_inflow" string="Cash Inflow (AED)" readonly="1"/>
              <field name="total_outflow" string="Cash Outflow (AED)" readonly="1"/>
              <field name="net_cash" string="Net Cash Position (AED)" readonly="1"/>
            </group>
          </group>

          <group string="📄 Invoicing">
            <group>
              <field name="overdue_count" string="Overdue Invoices" readonly="1"/>
              <field name="total_overdue" string="Total Overdue (AED)" readonly="1"/>
            </group>
          </group>

          <group string="📊 CRM Pipeline">
            <group>
              <field name="open_opportunities" string="Open Deals" readonly="1"/>
              <field name="pipeline_value" string="Pipeline Value (AED)" readonly="1"/>
            </group>
          </group>

          <group string="👥 Workforce">
            <group>
              <field name="employee_count" string="Active Employees" readonly="1"/>
            </group>
          </group>

          <group string="🏥 Health and Alerts">
            <group>
              <field name="health_score" string="Health Score (/100)" readonly="1"/>
              <field name="insights_critical" string="Critical Alerts" readonly="1"/>
              <field name="insights_high" string="High Alerts" readonly="1"/>
              <field name="insights_medium" string="Medium Alerts" readonly="1"/>
            </group>
          </group>

          <group string="📝 Executive Summary">
            <field name="report_notes" readonly="1" nolabel="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_financial_report_list" model="ir.ui.view">
    <field name="name">smartfinance.report.list</field>
    <field name="model">smartfinance.report</field>
    <field name="arch" type="xml">
      <list string="Financial Reports" create="false">
        <field name="name"/>
        <field name="date_generated"/>
        <field name="health_score"/>
        <field name="total_overdue"/>
        <field name="net_cash"/>
      </list>
    </field>
  </record>

  <record id="action_generate_financial_report" model="ir.actions.server">
    <field name="name">Generate Financial Report</field>
    <field name="model_id" ref="model_smartfinance_report"/>
    <field name="state">code</field>
    <field name="code">action = model.generate_report()</field>
  </record>

  <record id="action_smartfinance_report" model="ir.actions.act_window">
    <field name="name">Financial Reports</field>
    <field name="res_model">smartfinance.report</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>