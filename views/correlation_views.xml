<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_correlation_list" model="ir.ui.view">
    <field name="name">smartfinance.correlation.list</field>
    <field name="model">smartfinance.correlation</field>
    <field name="arch" type="xml">
      <list string="Cross-Module Correlations"
            decoration-danger="strength in ('strong_positive','strong_negative')"
            decoration-warning="strength in ('moderate_positive','moderate_negative')"
            decoration-muted="strength == 'weak'">
        <field name="name"/>
        <field name="module_a"/>
        <field name="module_b"/>
        <field name="correlation_score"/>
        <field name="strength"/>
        <field name="is_significant"/>
        <field name="data_points"/>
      </list>
    </field>
  </record>

  <record id="view_correlation_form" model="ir.ui.view">
    <field name="name">smartfinance.correlation.form</field>
    <field name="model">smartfinance.correlation</field>
    <field name="arch" type="xml">
      <form string="Correlation Detail">
        <sheet>
          <h1><field name="name" readonly="1"/></h1>
          <group>
            <group string="Modules">
              <field name="module_a" string="Module A" readonly="1"/>
              <field name="module_b" string="Module B" readonly="1"/>
              <field name="metric_a" string="Metric A" readonly="1"/>
              <field name="metric_b" string="Metric B" readonly="1"/>
            </group>
            <group string="Results">
              <field name="correlation_score" string="Correlation Score" readonly="1"/>
              <field name="strength" string="Strength" readonly="1"/>
              <field name="is_significant" string="Significant" readonly="1"/>
              <field name="data_points" string="Months Analyzed" readonly="1"/>
            </group>
          </group>
          <group string="What This Means">
            <field name="interpretation" nolabel="1" readonly="1"/>
          </group>
          <group string="Recommended Action">
            <field name="recommended_action" nolabel="1" readonly="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_correlation_kanban" model="ir.ui.view">
    <field name="name">smartfinance.correlation.kanban</field>
    <field name="model">smartfinance.correlation</field>
    <field name="arch" type="xml">
      <kanban default_group_by="strength" quick_create="false">
        <field name="name"/>
        <field name="module_a"/>
        <field name="module_b"/>
        <field name="correlation_score"/>
        <field name="strength"/>
        <field name="is_significant"/>
        <templates>
          <t t-name="card">
            <div class="oe_kanban_global_click">
              <strong><t t-out="record.name.value"/></strong>
              <div>
                <t t-out="record.module_a.value"/> vs
                <t t-out="record.module_b.value"/>
              </div>
              <div>Score: <t t-out="record.correlation_score.value"/></div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <record id="action_smartfinance_correlation" model="ir.actions.act_window">
    <field name="name">Cross-Module Correlations</field>
    <field name="res_model">smartfinance.correlation</field>
    <field name="view_mode">list,kanban,form</field>
  </record>

  <record id="action_run_correlation" model="ir.actions.server">
    <field name="name">Run Correlation Analysis</field>
    <field name="model_id" ref="model_smartfinance_correlation"/>
    <field name="state">code</field>
    <field name="code">model.run_correlation_analysis()</field>
  </record>

</odoo>