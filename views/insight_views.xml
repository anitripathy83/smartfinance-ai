<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_insight_list" model="ir.ui.view">
    <field name="name">smartfinance.insight.list</field>
    <field name="model">smartfinance.insight</field>
    <field name="arch" type="xml">
      <list string="AI Insights"
            decoration-danger="severity=='critical'"
            decoration-warning="severity=='high'"
            decoration-info="severity=='medium'">
        <field name="name"/>
        <field name="category"/>
        <field name="severity"/>
        <field name="value"/>
        <field name="is_resolved"/>
        <field name="create_date"/>
        <button name="mark_resolved" type="object" string="Resolve"
                icon="fa-check"
                invisible="is_resolved == True"/>
      </list>
    </field>
  </record>

  <record id="view_insight_form" model="ir.ui.view">
    <field name="name">smartfinance.insight.form</field>
    <field name="model">smartfinance.insight</field>
    <field name="arch" type="xml">
      <form string="AI Insight">
        <header>
          <button name="mark_resolved" type="object" string="Mark Resolved"
                  class="oe_highlight"
                  invisible="is_resolved == True"/>
        </header>
        <sheet>
          <group>
            <field name="name"/>
            <field name="severity"/>
            <field name="category"/>
            <field name="value"/>
            <field name="is_resolved"/>
          </group>
          <notebook>
            <page string="Analysis">
              <field name="description"/>
            </page>
            <page string="Recommended Action">
              <field name="recommended_action"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_insight_kanban" model="ir.ui.view">
    <field name="name">smartfinance.insight.kanban</field>
    <field name="model">smartfinance.insight</field>
    <field name="arch" type="xml">
      <kanban default_group_by="severity" quick_create="false">
        <field name="name"/>
        <field name="category"/>
        <field name="severity"/>
        <field name="description"/>
        <field name="is_resolved"/>
        <templates>
          <t t-name="card">
            <div class="oe_kanban_global_click">
              <strong><t t-out="record.name.value"/></strong>
              <div><t t-out="record.category.value"/></div>
              <div><t t-out="record.severity.value"/></div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <record id="action_smartfinance_insights" model="ir.actions.act_window">
    <field name="name">AI Insights</field>
    <field name="res_model">smartfinance.insight</field>
    <field name="view_mode">kanban,list,form</field>
    <field name="domain">[('is_resolved','=',False)]</field>
  </record>

  <record id="action_smartfinance_health" model="ir.actions.act_window">
    <field name="name">Financial Health Score</field>
    <field name="res_model">smartfinance.health.score</field>
    <field name="view_mode">list,kanban</field>
  </record>

</odoo>